{
  "version": 2,
  "installCommand": "cd ../.. && npm install -g pnpm && pnpm install",
  "buildCommand": "cd ../.. && BASE_PATH=/ NODE_ENV=production pnpm --filter @workspace/fb-guard build",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production",
    "BASE_PATH": "/"
  },
  "build": {
    "env": {
      "NODE_ENV": "production",
      "BASE_PATH": "/",
      "VITE_API_URL": "@vite_api_url"
    }
  }
}
